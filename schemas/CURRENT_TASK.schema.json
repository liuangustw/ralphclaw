{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralph-claw.local/schemas/CURRENT_TASK.schema.json",
  "title": "Ralph-Claw Current Task",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "description",
    "allowed_files",
    "forbidden_files",
    "acceptance",
    "test_commands",
    "stop_condition"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task_[0-9]{3,}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "allowed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "test",
              "lint",
              "build",
              "runtime",
              "file_check",
              "manual"
            ]
          },
          "command": {
            "type": "string"
          },
          "expected": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "test_commands": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "max_retries": {
      "type": "integer",
      "minimum": 0,
      "default": 3
    }
  },
  "additionalProperties": false
}
